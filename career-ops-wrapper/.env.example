# Local development defaults. Do not store secrets in this file.
CAREER_OPS_HOST=127.0.0.1
CAREER_OPS_PORT=3000
# Required when binding beyond localhost, for example CAREER_OPS_HOST=0.0.0.0.
# This is a Local Pairing Token for your personal LAN wrapper, not account auth
# and not Firebase App Check.
CAREER_OPS_PAIRING_TOKEN=
