{
  "module": "app",
  "dimension": "evironment",
  "flavors": {
    "dev": {
      "applicationIdSuffix": ".dev",
      "appName": "[DEV] JobFlow",
      "buildConfigFields": {
        "CAREER_OPS_ENVIRONMENT": "dev",
        "CAREER_OPS_DEFAULT_BASE_URL": "http://10.0.2.2:3000"
      }
    },
    "prod": {
      "applicationIdSuffix": "",
      "appName": "JobFlow",
      "buildConfigFields": {
        "CAREER_OPS_ENVIRONMENT": "prod",
        "CAREER_OPS_DEFAULT_BASE_URL": ""
      }
    }
  },
  "networkSecurity": {
    "enabled": false
  },
  "packageName": {
    "applicationId": "me.dthuy.jobflow",
