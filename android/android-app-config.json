    "appIcons": {
      "image": "",
      "backgroundColor": "#FFFFFF",
      "monochromeImage": ""
    },
    "splashScreens": {
      "image": "",
      "backgroundColor": "#FFFFFF",
      "darkImage": "",
      "darkBackgroundColor": ""
    },
    "generateLauncherIcon": true,
    "generateAdaptiveIcon": true,
    "generateSplashIcon": true,
    "generateNotificationIcon": true
